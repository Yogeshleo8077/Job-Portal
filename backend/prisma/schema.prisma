// Prisma schema — AI-Ready Job Portal
// Module 4: Users, Roles, Companies, Jobs, Applications, SavedJobs (+ ScrapedJob for Module 5)
// Proper relationships, constraints and indexing throughout.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYER
  CANDIDATE
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CANDIDATE)

  // Candidate profile fields
  headline     String?
  bio          String?
  skills       String[] @default([])
  resumeUrl    String?
  location     String?

  // Password reset (Module 1 — optional forgot password)
  resetToken        String?
  resetTokenExpiry  DateTime?

  // Relations
  company        Company?      @relation(fields: [companyId], references: [id])
  companyId      String?
  postedJobs     Job[]         @relation("PostedBy")
  applications   Application[]
  savedJobs      SavedJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([email])
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  website     String?
  description String?
  logoUrl     String?
  location    String?

  employees User[]
  jobs      Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Job {
  id             String         @id @default(cuid())
  title          String
  description    String
  location       String
  workMode       WorkMode       @default(ONSITE)
  employmentType EmploymentType @default(FULL_TIME)
  salaryMin      Int?
  salaryMax      Int?
  currency       String         @default("INR")
  experienceMin  Int?           // years
  experienceMax  Int?           // years
  skills         String[]       @default([])
  benefits       String[]       @default([])
  deadline       DateTime?
  status         JobStatus      @default(OPEN)

  // Relations
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   String
  postedBy    User    @relation("PostedBy", fields: [postedById], references: [id], onDelete: Cascade)
  postedById  String

  applications Application[]
  savedBy      SavedJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([location])
  @@index([workMode])
  @@index([employmentType])
  @@index([companyId])
  @@index([postedById])
  @@index([createdAt])
}

model Application {
  id          String            @id @default(cuid())
  status      ApplicationStatus @default(APPLIED)
  coverLetter String?
  resumeUrl   String?
  // AI Resume Matching (bonus) — score cached at apply time
  matchScore  Int?
  matchNotes  String?

  job         Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId       String
  candidate   User   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A candidate can only apply once per job
  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([status])
}

model SavedJob {
  id          String @id @default(cuid())
  job         Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId       String
  candidate   User   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId String

  createdAt DateTime @default(now())

  @@unique([jobId, candidateId])
  @@index([candidateId])
}

// Module 5 — Job Scraping. Stored separately from employer-posted Jobs.
model ScrapedJob {
  id          String   @id @default(cuid())
  source      String   // e.g. "remoteok", "arbeitnow"
  sourceUrl   String   @unique // used to prevent duplicate records
  externalId  String?  // stable id from source when available
  title       String
  company     String
  location    String?
  description String?
  skills      String[] @default([])
  postedDate  DateTime?

  scrapedAt DateTime @default(now())

  @@index([source])
  @@index([company])
  @@index([scrapedAt])
}
