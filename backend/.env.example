# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobportal?schema=public

# --- JWT ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- AI Resume Matching (bonus). Leave blank to use the heuristic fallback. ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Scraper scheduler (bonus). Set to true to scrape every 6 hours. ---
SCRAPER_ENABLE_CRON=false
SCRAPER_CRON=0 */6 * * *
