{
  "info": {
    "name": "AI-Ready Job Portal API",
    "description": "Full Stack Engineer assessment. Set {{baseUrl}} (default http://localhost:4000/api). Login requests auto-save {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" },
    { "key": "jobId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (candidate)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Candidate\",\n  \"email\": \"newcandidate@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"CANDIDATE\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.accessToken) { pm.collectionVariables.set('token', data.accessToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@jobportal.dev\",\n  \"password\": \"Password@123\"\n}"
            }
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"candidate@jobportal.dev\" }"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"headline\": \"Senior Engineer\",\n  \"skills\": [\"React\", \"Node.js\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List jobs (filter/sort/paginate)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs?search=engineer&workMode=REMOTE&sortBy=createdAt&page=1&limit=10"
          }
        },
        {
          "name": "Get job by id",
          "request": { "method": "GET", "url": "{{baseUrl}}/jobs/{{jobId}}" }
        },
        {
          "name": "Create job (employer/admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/jobs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"DevOps Engineer\",\n  \"description\": \"Own CI/CD, infra as code, and observability across our platform.\",\n  \"location\": \"Remote\",\n  \"workMode\": \"REMOTE\",\n  \"employmentType\": \"FULL_TIME\",\n  \"salaryMin\": 2000000,\n  \"salaryMax\": 3500000,\n  \"skills\": [\"Docker\", \"Kubernetes\", \"AWS\"]\n}"
            }
          }
        },
        {
          "name": "Update job",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/jobs/{{jobId}}",
            "body": { "mode": "raw", "raw": "{ \"title\": \"Updated Title\" }" }
          }
        },
        {
          "name": "Close job",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/{{jobId}}/close"
          }
        },
        {
          "name": "Delete job",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Apply to job (candidate)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/jobs/{{jobId}}/apply",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coverLetter\": \"I'm excited to apply.\",\n  \"resumeText\": \"5 years of React and Node.js experience...\"\n}"
            }
          }
        },
        {
          "name": "Save job (candidate)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/{{jobId}}/save"
          }
        },
        {
          "name": "List applicants (employer/admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/{{jobId}}/applicants"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "My applications (candidate)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications"
          }
        }
      ]
    },
    {
      "name": "Scraper",
      "item": [
        {
          "name": "Run scraper (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/scrape/jobs",
            "body": { "mode": "raw", "raw": "{ \"sources\": [\"remoteok\", \"arbeitnow\"] }" }
          }
        },
        {
          "name": "List scraped jobs",
          "request": { "method": "GET", "url": "{{baseUrl}}/scrape/jobs?page=1&limit=20" }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard stats (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "AI resume match",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/ai/match",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{jobId}}\",\n  \"resumeText\": \"Experienced full stack developer with React, Node.js, PostgreSQL.\"\n}"
            }
          }
        }
      ]
    }
  ]
}
