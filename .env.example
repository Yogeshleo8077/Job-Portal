# Root env for docker-compose. Copy to .env and adjust.

# JWT secrets (change these!)
JWT_ACCESS_SECRET=super_secret_access_change_me
JWT_REFRESH_SECRET=super_secret_refresh_change_me

# AI Resume Matching (bonus). Leave blank to use the heuristic fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Set to true to auto-scrape jobs every 6 hours.
SCRAPER_ENABLE_CRON=false
